# Sage Environment Variables
# Copy this file to .env and fill in the values

# ===================
# REQUIRED (Production)
# ===================

# JWT signing secret — minimum 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ===================
# OPTIONAL
# ===================

# Server port (default: 3001)
# PORT=3001

# Encryption for stored API keys (both required together, or omit both)
# ENCRYPTION_KEY must be at least 32 characters
# ENCRYPTION_SALT must be at least 16 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=
# ENCRYPTION_SALT=

# Comma-separated list of allowed CORS origins
# Default (dev): http://localhost:5173,http://localhost:5174
# Default (prod via Docker): http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:3000

# Log level: trace, debug, info, warn, error, fatal (default: info)
# LOG_LEVEL=info

# Node environment (set automatically in Docker)
# NODE_ENV=production
